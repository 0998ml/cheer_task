<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cheer Task" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    
  </head>

  <body>
    <%# --- Bootstrap ナビゲーションバー --- %>
    <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm mb-4">
      <div class="container">
        <%# ロゴ部分 %>
        <%= link_to "CheerTASK", root_path, class: "navbar-brand fw-bold" %>

        <%# スマホ用の三本線ボタン %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <%# メニューの中身 %>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>

            <% if session[:user_id] %>
              <li class="nav-item">
                <%= link_to "マイページ", user_path(session[:user_id]), class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "新規投稿", new_task_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "タスク", tasks_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "ユーザー", users_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "nav-link text-danger" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "新規登録", signup_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "ログイン", login_path, class: "nav-link" %>
              </li>
            <% end %>

            <%# 管理者メニュー %>
            <% if current_user && current_user.admin? %>
              <li class="nav-item border-start ms-lg-2 ps-lg-2">
                <%= link_to '管理画面', admin_users_path, class: "nav-link text-secondary" %>
              </li>
              <li class="nav-item">
                <%= link_to 'タスク管理', admin_tasks_path, class: "nav-link text-secondary" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# --- フラッシュメッセージ（BootstrapのAlertを使用） --- %>
    <div class="container">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <%# --- メインコンテンツ --- %>
    <main class="container">
      <%= yield %>
    </main>
  </body>
