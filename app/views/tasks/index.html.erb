<h1>タスク一覧</h1>

<%= link_to '新しいタスクを作成', new_task_path %>

<div class="kanban-board">

  <div class="kanban-column">
    <h2 class="column-title">未対応</h2>

    <% @tasks.each do |task| %>
      <% if task.status != 'done' %>
        <div class="task-card">
          <h3><%= task.title %></h3>
          <p><%= task.body %></p>
          <p class="task-user">投稿者：<%= task.user.name %></p>

          <div class="cheer-section">
            <% if current_user.cheered?(task) %>
              <%= button_to task_cheers_path(task), method: :delete, class: "cheer-btn active" do %>
                💖 <%= task.cheers.count %>
              <% end %>
            <% else %>
              <%= button_to task_cheers_path(task), method: :post, class: "cheer-btn" do %>
                🤍 <%= task.cheers.count %>
              <% end %>
            <% end %>
          </div>
          <% if current_user == task.user %>
            <%= button_to '✅ 完了にする', task_path(task, task: { status: 'done' }), method: :patch, form_class: 'status-form' %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="kanban-column">
    <h2 class="column-title">完了</h2>

    <% @tasks.each do |task| %>
      <% if task.status == 'done' %>
        <div class="task-card">
          <h3><%= task.title %></h3>
          <p><%= task.body %></p>
          <p class="task-user">投稿者：<%= task.user.name %></p>

          <div class="cheer-section">
            <% if current_user.cheered?(task) %>
              <%= button_to task_cheers_path(task), method: :delete, class: "cheer-btn active" do %>
                💖 <%= task.cheers.count %>
              <% end %>
            <% else %>
              <%= button_to task_cheers_path(task), method: :post, class: "cheer-btn" do %>
                🤍 <%= task.cheers.count %>
              <% end %>
            <% end %>
          </div>
          <% if current_user == task.user %>
            <%= button_to '↩️ 未対応に戻す', task_path(task, task: { status: 'todo' }), method: :patch, form_class: 'status-form' %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

</div>

<style>
  /* ボード全体を横並び（2列）にする */
  .kanban-board {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    align-items: flex-start;
  }

  /* 縦の列のデザイン */
  .kanban-column {
    flex: 1;
    background-color: #f4f5f7;
    padding: 20px;
    border-radius: 8px;
  }

  .column-title {
    font-size: 1.2rem;
    margin-bottom: 15px;
    color: #333;
    border-bottom: 2px solid #ddd;
    padding-bottom: 5px;
  }

  /* 白いカード（タスク）のデザイン */
  .task-card {
    background-color: #ffffff;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .task-card h3 {
    margin: 0 0 10px 0;
    font-size: 1.1rem;
    color: #2c3e50;
  }

  .task-card p {
    margin: 0 0 10px 0;
    color: #555;
  }

  .task-user {
    font-size: 0.85rem;
    color: #888;
    text-align: right;
    margin: 0 !important;
  }

  /* Cheerボタンのデザイン */
  .cheer-section {
    margin-top: 10px;
    margin-bottom: 10px;
  }

  .cheer-btn {
    background: none;
    border: 1px solid #ddd;
    border-radius: 20px;
    padding: 5px 12px;
    cursor: pointer;
    font-size: 0.9rem;
    color: #555;
    transition: all 0.2s;
  }

  .cheer-btn.active {
    background-color: #ffeef0;
    border-color: #ffc1cc;
    color: #e83e8c;
  }

  .cheer-btn:hover {
    background-color: #f8f9fa;
  }
</style>