<h1>タスク一覧</h1>

<%= link_to '新しいタスクを作成', new_task_path %> <div class="kanban-board">
  
  <div class="kanban-column">
    <h2 class="column-title">未対応</h2>
    
    <% @tasks.each do |task| %>
      <% if task.status != 'done' %> <div class="task-card">
          <h3><%= task.title %></h3>
          <p><%= task.body %></p>
          <p class="task-user">投稿者：<%= task.user.name %></p>

          <% if current_user == task.user %> <%= button_to '✅ 完了にする', task_path(task, task: { status: 'done' }), method: :patch, form_class: 'status-form' %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="kanban-column">
    <h2 class="column-title">完了</h2>
    
    <% @tasks.each do |task| %>
      <% if task.status == 'done' %> <div class="task-card">
          <h3><%= task.title %></h3>
          <p><%= task.body %></p>
          <p class="task-user">投稿者：<%= task.user.name %></p>

          <% if current_user == task.user %>
            <%= button_to '↩️ 未対応に戻す', task_path(task, task: { status: 'todo' }), method: :patch, form_class: 'status-form' %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

</div>

<style>
  /* ボード全体を横並び（2列）にする */
  .kanban-board {
    display: flex;
    gap: 20px; /* 列と列の隙間 */
    margin-top: 20px;
    align-items: flex-start;
  }

  /* 縦の列のデザイン */
  .kanban-column {
    flex: 1; /* 左右の列を同じ幅にする */
    background-color: #f4f5f7; /* 薄いグレーの背景 */
    padding: 20px;
    border-radius: 8px; /* 角を丸く */
  }

  .column-title {
    font-size: 1.2rem;
    margin-bottom: 15px;
    color: #333;
    border-bottom: 2px solid #ddd;
    padding-bottom: 5px;
  }

  /* 白いカード（タスク）のデザイン */
  .task-card {
    background-color: #ffffff;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); /* 影をつけて立体的に！ */
  }

  .task-card h3 {
    margin: 0 0 10px 0;
    font-size: 1.1rem;
    color: #2c3e50;
  }

  .task-card p {
    margin: 0 0 10px 0;
    color: #555;
  }

  .task-user {
    font-size: 0.85rem;
    color: #888;
    text-align: right; /* 投稿者は右寄せにしてスッキリ見せる */
    margin: 0 !important;
  }
</style>