<h1>タスク詳細</h1>

<div style="border: 1px solid #ccc; padding: 20px;">
  <h2><%= @task.title %></h2>
  <p><%= @task.body %></p>
  <p>投稿者: <%= link_to @task.user.name, user_path(@task.user) %></p>

  <%# 要件10：自分の投稿の時だけ「編集」「削除」を表示する %>
  <% if @task.user == current_user %>
    <hr>
    <%= link_to "編集する", edit_task_path(@task) %> |
    
    <%# 要件9：削除前にアラートを表示する（turbo_confirm） %>
    <%= link_to "削除する", task_path(@task), 
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
  <% end %>
</div>

<div style="margin-top: 20px;">
  <%= link_to "一覧に戻る", tasks_path %>
</div>

<div class="comments-section">
  <h3>💬 コメント (<%= @task.comments.count %>件)</h3>

  <div class="comments-list">
    <% @task.comments.each do |comment| %>
      <div class="comment-card">
        <p class="comment-user">
          <span class="user-icon">👤</span> <strong><%= comment.user.name %></strong>
        </p>
        <p class="comment-content"><%= comment.content %></p>
        
        <% if comment.user == current_user %>
          <%= button_to "削除する", task_comment_path(@task, comment), method: :delete, class: "delete-comment-btn" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="comment-form">
    <%= form_with(model: [@task, Comment.new], local: true) do |f| %>
      <%= f.text_area :content, placeholder: "応援メッセージやアドバイスを入力...", rows: 3, class: "comment-input", required: true %>
      <div class="form-actions">
        <%= f.submit "コメントを送信", class: "comment-submit-btn" %>
      </div>
    <% end %>
  </div>
</div>
<style>
  /* コメントセクション全体 */
  .comments-section {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 2px dashed #ddd;
  }

  .comments-section h3 {
    color: #2c3e50;
    margin-bottom: 20px;
  }

  /* コメントカード */
  .comments-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 30px;
  }

  .comment-card {
    background-color: #f8f9fa;
    padding: 15px;
    border-radius: 8px;
    border-left: 4px solid #3498db;
  }

  .comment-user {
    font-size: 0.9rem;
    color: #555;
    margin: 0 0 10px 0;
  }

  .comment-content {
    margin: 0 0 10px 0;
    color: #333;
    line-height: 1.5;
  }

  /* 削除ボタン */
  .delete-comment-btn {
    background: none;
    border: none;
    color: #e74c3c;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0;
    text-decoration: underline;
  }

  /* コメント入力フォーム */
  .comment-input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 1rem;
    margin-bottom: 10px;
    resize: vertical;
  }

  .comment-submit-btn {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    transition: 0.2s;
  }

  .comment-submit-btn:hover {
    background-color: #2980b9;
  }
</style>