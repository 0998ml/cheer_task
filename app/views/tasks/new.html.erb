<h1>タスク新規投稿</h1>

<%# form_withに @task を渡すことで、Railsが自動的に「新規作成用のフォーム」だと判断します %>
<%= form_with model: @task, local: true do |f| %>

  <%# 失敗した際のエラーメッセージを表示させる %>
  <% if @task.errors.any? %>
    <div style="color: red;">
      <h3><%= @task.errors.count %>件のエラーがあります:</h3>
      <ul>
        <% @task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body, "内容" %><br>
    <%= f.text_area :body %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :group_id, "グループ" %><br> <%# .distinctで重複しているデータは1つにまとめる #%>
    <%= f.collection_select :group_id, current_user.groups.distinct, :id, :name, { include_blank: "選択しない（未分類）" }, { style: "padding: 5px; border-radius: 4px;" } %>
  </div> 

  <div style="margin-top: 20px;">
    <%= f.submit "投稿する" %>
  </div>

<% end %>

<%= link_to "一覧に戻る", tasks_path %>