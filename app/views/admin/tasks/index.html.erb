<h1>管理者専用：タスク管理</h1>

<table border="1">
  <thead>
    <tr>
      <th>ID</th>
      <th>タイトル</th>
      <th>内容</th>
      <th>投稿者</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.id %></td>
        <td><%= task.title %></td>
        <td><%= task.body %></td>
        <td><%= task.user.name %></td> <td>
          <%= button_to '削除', admin_task_path(task), method: :delete, form: { data: { turbo_confirm: 'このタスクを強制削除してよろしいですか？' } } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>